# ============================================================
# pi_n8n_stack — Environment Variables
# ============================================================
# Copy to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- n8n Auth (REQUIRED) ------------------------------------
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=               # REQUIRED — pick a strong password
N8N_ENCRYPTION_KEY=                    # REQUIRED — random string for credential encryption

# --- n8n Settings -------------------------------------------
N8N_WEBHOOK_URL=http://192.168.0.11:5678
TZ=Europe/Stockholm
