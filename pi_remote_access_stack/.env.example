# ============================================================================
# Pi Remote Access Stack — Environment Variables
# ============================================================================
# Copy this file to .env and edit the values:
#   cp .env.example .env && nano .env
# ============================================================================

# --- Timezone ---
TZ=Europe/Stockholm

# --- Raspberry Pi Host IP ---
HOST_IP=192.168.1.100

# --- Home LAN Subnet (for Tailscale subnet routing) ---
# This allows your work laptop to access all services on the LAN
LAN_SUBNET=192.168.1.0/24

# ============================================================================
# TAILSCALE
# ============================================================================
# Generate an auth key at: https://login.tailscale.com/admin/settings/keys
#   - Type: Reusable (recommended for headless Pi)
#   - Expiry: 90 days or No expiry
#   - Tags: tag:pi (optional, for ACL policies)
# ============================================================================
TAILSCALE_AUTHKEY=tskey-auth-XXXXXXXXXXXX-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TAILSCALE_HOSTNAME=pi5
